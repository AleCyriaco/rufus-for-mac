{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rufus",
  "version": "0.1.0",
  "identifier": "com.alecyriaco.rufus-mac",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rufus 0.1.0 (mac)",
        "width": 480,
        "height": 860,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "copyright": "© 2026 Ale Cyriaco — MIT"
  }
}
